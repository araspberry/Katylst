# EmailJS — get these from your EmailJS dashboard (emailjs.com)
NEXT_PUBLIC_EMAILJS_KEY=your_public_key_here
NEXT_PUBLIC_EMAILJS_SERVICE=your_service_id_here
NEXT_PUBLIC_EMAILJS_TEMPLATE=your_template_id_here

# Google PageSpeed Insights API key (optional — raises rate limit from ~3/min to 400/100sec)
# Get one free at: console.cloud.google.com → Enable "PageSpeed Insights API"
GOOGLE_PSI_KEY=your_google_api_key_here

# Phase 3 — Real audit backend URL (swap in when Kali's backend is deployed)
# AUDIT_BACKEND_URL=https://your-audit-backend.com
